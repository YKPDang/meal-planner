{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "DATABASE_PATH": "${workspaceFolder}/backend/meal_planner.db",
        "SMART_RANDOM_LOOKBACK_DAYS": "7"
      },
      "justMyCode": true
    },
    {
      "name": "Frontend: Vite dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run dev",
      "env": {
        "VITE_API_URL": "http://localhost:8000/api"
      },
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Frontend: Firefox",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "pathMapping": {
        "/": "${workspaceFolder}/frontend/",
        "/src": "${workspaceFolder}/frontend/src"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full stack: backend + frontend + browser",
      "configurations": [
        "Backend: FastAPI (uvicorn)",
        "Frontend: Vite dev server",
        "Frontend: Firefox"
      ]
    }
  ]
}